# ─── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# ─── Virtual Environments ───────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ─── Data Files ─────────────────────────────────────────────
# Raw and processed data should NOT be committed to version control
data/raw/
data/processed/

# ─── Trained Model Artifacts ────────────────────────────────
# Serialised model binaries are large; regenerate with src/train.py
models/*.pkl

# ─── Jupyter / IPython ──────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Testing & Coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ─── IDE & Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Secrets & Environment ──────────────────────────────────
# NEVER commit API keys, credentials, or environment-specific secrets
*.env
.env.*
secrets.toml
.streamlit/secrets.toml

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/

# ─── Misc ───────────────────────────────────────────────────
*.tmp
*.bak
