# ─── Data Files ─────────────────────────────────────────────
# Raw CSV and processed pickle are committed for Streamlit Cloud deployment
# (all files are < 1 MB — well within GitHub limits)
# data/raw/
# data/processed/

# ─── Trained Model Artifacts ────────────────────────────────
# Model artifacts are committed for Streamlit Cloud deployment (~470 KB total)
# Regenerate locally with: python src/train.py
# models/*.pkl

# ─── Jupyter / IPython ──────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

